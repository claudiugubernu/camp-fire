rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile only
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']);
    }

    // Check-ins: user can read/create their own; no delete/update
    match /checkins/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll(['userId', 'dayId', 'completedAt', 'earlyBird']);
      allow list: if request.auth != null;
    }

    // Days config: anyone authenticated can read; only admin writes (enforce via Admin SDK)
    match /days/{dayId} {
      allow read: if request.auth != null;
      allow write: if false; // Use Admin SDK / trusted server for writes
    }
  }
}
